# Native host-run example
# Use this when the app runs directly on your machine.

# Security
JWT_SECRET_KEY=change-me-to-a-long-random-secret

# HTTP / CORS
HOST=0.0.0.0
PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# Logging / profiling
REQUEST_LOG_ENABLED=true
AUDIT_LOG_ENABLED=true
APP_PROFILING_ENABLED=false
APP_FUNCTION_PROFILING_ENABLED=false

# Bootstrap
BOOTSTRAP_SUPERUSER_CREATE=false
BOOTSTRAP_SUPERUSER_USERNAME=admin
BOOTSTRAP_SUPERUSER_PASSWORD=change-me

# Rate limit
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=20

# Redis
# Native app -> Docker Redis should use localhost.
# Docker app uses docker-compose override for REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
REDIS_DEFAULT_TTL_SECONDS=3600
REDIS_HEARTBEAT_ENABLED=true
REDIS_HEARTBEAT_SCHEDULE_SECONDS=60,600,1200,3600,14400,28800,43200
