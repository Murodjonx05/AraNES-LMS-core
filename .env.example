# Required security settings
JWT_SECRET_KEY=change-me-to-a-long-random-secret

# Bearer auth + CORS (trusted frontend origins only, comma-separated)
CORS_ALLOW_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# Optional app runtime settings
HOST=0.0.0.0
PORT=8000

# Optional non-interactive superuser bootstrap on app startup
BOOTSTRAP_SUPERUSER_CREATE=false
BOOTSTRAP_SUPERUSER_USERNAME=admin
BOOTSTRAP_SUPERUSER_PASSWORD=change-me