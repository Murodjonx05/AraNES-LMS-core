# Native host-run example
# Use this when the app runs directly on your machine.

# Runtime
ENVIRONMENT=development

# Security
JWT_SECRET_KEY=change-me-to-a-long-random-secret
# DATABASE_URL=sqlite+aiosqlite:///./data/db.sqlite3

# HTTP / CORS
HOST=0.0.0.0
PORT=8000
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=60
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
CORS_ALLOW_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# Logging / profiling
LOG_LEVEL=INFO
REQUEST_LOG_ENABLED=true
AUDIT_LOG_ENABLED=true
APP_PROFILING_ENABLED=false
APP_FUNCTION_PROFILING_ENABLED=false
# APP_PROFILE_LOG_DIR=./logs

# Bootstrap
# Native/dev runs keep startup DB bootstrap enabled by default.
# Compose overrides this to false and uses the dedicated prestart step instead.
BOOTSTRAP_SUPERUSER_CREATE=false
BOOTSTRAP_SUPERUSER_USERNAME=admin
BOOTSTRAP_SUPERUSER_PASSWORD=change-me

# Rate limit
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=20
STARTUP_DB_BOOTSTRAP_ENABLED=true

# Password hashing
# PBKDF2_ITERATIONS=100000
# ARGON2_TIME_COST=3
# ARGON2_MEMORY_COST=65536
# ARGON2_PARALLELISM=4

# Redis
# Native app -> Docker Redis should use localhost.
# Docker app always uses bundled Compose Redis at redis://redis:6379/0.
# Set REDIS_ENABLED=false if you do not want Redis in a native dev run.
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
REDIS_DEFAULT_TTL_SECONDS=3600
REDIS_HEARTBEAT_ENABLED=true
REDIS_HEARTBEAT_SCHEDULE_SECONDS=60,600,1200,3600,14400,28800,43200
